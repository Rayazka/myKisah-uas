@page "/journals/new"
@rendermode InteractiveServer

@inject IJournalService JournalService
@inject ICharacterService CharacterService
@inject UserSession Session
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject IUserService UserService

<PageTitle>Tulis Journal — myKisah</PageTitle>

<div class="container-fluid">
    <div class="create-container">
        <h1 class="mb-3">Tulis Journal Baru</h1>

        <AlertMessage Message="_error" IsError="true" Show="_hasError" />

        <div class="card">
            <div class="card-body">
                @* Title *@
                <div class="mb-3">
                    <label class="form-label fw-bold">Judul</label>
                    <input @bind="_title"
                           type="text"
                           class="form-control"
                           placeholder="Apa yang ingin kamu tulis hari ini?"
                           disabled="@_saving"
                           maxlength="100" />
                    <small class="text-muted">@_title.Length/100 karakter</small>
                </div>

                @* Content *@
                <div class="mb-3">
                    <label class="form-label fw-bold">Isi Journal</label>
                    <textarea @bind="_content"
                              class="form-control"
                              rows="6"
                              placeholder="Tulis isi journalmu di sini..."
                              disabled="@_saving"></textarea>
                    <small class="text-muted @(_content.Length > _maxLength ? "text-danger" : "")">
                        @_content.Length/@_maxLength karakter
                    </small>
                </div>

                @* Mood *@
                <div class="mb-4">
                    <label class="form-label fw-bold">Mood</label>
                    <MoodPicker @bind-SelectedMood="_mood" Disabled="_saving" />
                </div>

                @* Character *@
                <div class="mb-4">
                    <label class="form-label fw-bold">Character Companion</label>
                    <select @bind="_selectedCharacterId" class="form-select" disabled="@_saving">
                        <option value="">-- Tanpa karakter --</option>
                        @foreach (var c in _characters)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>

                @* Buttons *@
                <div class="d-flex gap-2">
                    <button class="btn btn-primary"
                            @onclick="CreateJournal"
                            disabled="@_saving">
                        @(_saving ? "Menyimpan..." : "Simpan Journal")
                    </button>
                    <button class="btn btn-outline-secondary"
                            @onclick="Cancel"
                            disabled="@_saving">
                        Batal
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _title = "";
    private string _content = "";
    private MoodType _mood = MoodType.Happy;
    private bool _saving;
    private string _error = "";
    private bool _hasError;
    private int _maxLength = 5000;
    private List<Character> _characters = new();
    private string _selectedCharacterId = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Session.IsLoggedIn)
        {
            var userId = await JS.InvokeAsync<string>("sessionStorage.getItem", "myKisah.userId");
            if (!string.IsNullOrEmpty(userId))
            {
                var user = UserService.GetAllUsers().FirstOrDefault(u => u.Id == userId);
                if (user != null) Session.Login(user);
            }
        }

        if (!Session.IsLoggedIn) { Navigation.NavigateTo("/", forceLoad: true); return; }

        _maxLength = Configuration.GetValue<int>("JournalConfig:MaxContentLength");
        _characters = CharacterService.GetAllCharacters().ToList();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CreateJournal()
    {

        // Try:
        //   JournalService.CreateJournal(
        //       Session.CurrentUser.Id,
        //       _title.Trim(),
        //       _content.Trim(),
        //       _mood)
        //   Navigation.NavigateTo("/journals")
        // Catch: _hasError = true, _error = ex.Message
        // Finally: _saving = false

        // Reset state error sebelum proses create journal dimulai
        _hasError = false;
        _error = "";

        // Validasi judul journal tidak boleh kosong
        if (string.IsNullOrWhiteSpace(_title.Trim()))
        {
            _hasError = true;
            _error = "Judul tidak boleh kosong.";
            return;
        }

        // Validasi jumlah karakter agar tidak melebihi batas konfigurasi
        if (_content.Length > _maxLength)
        {
            _hasError = true;
            _error = $"Isi journal terlalu panjang (max {_maxLength} karakter).";
            return;
        }

        try
        {
            // Mengaktifkan saving state untuk mencegah submit berulang
            _saving = true;

            // Membuat journal baru berdasarkan user yang sedang login
            var journal = JournalService.CreateJournal(
                Session.CurrentUser!.Id,
                _title.Trim(),
                _content.Trim(),
                _mood,
                string.IsNullOrEmpty(_selectedCharacterId) ? null : _selectedCharacterId
            );

            Navigation.NavigateTo($"/journals/{journal.Id}");
        }
        catch (Exception ex)
        {
            // Menampilkan pesan error dari service ke AlertMessage
            _hasError = true;
            _error = ex.Message;
        }
        finally
        {
            // Memastikan saving state selalu dimatikan setelah proses selesai
            _saving = false;
        }
    }

    private void Cancel()
    {
        // Redirect ke /journals
        Navigation.NavigateTo("/journals");
    }
}
