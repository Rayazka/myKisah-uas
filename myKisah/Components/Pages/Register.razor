@layout myKisah.Components.Layout.LoginLayout
@page "/register"
@rendermode InteractiveServer

@inject IUserService UserService
@inject UserSession Session
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>myKisah — Daftar</PageTitle>

<div class="login-card">
    <h1 class="brand">myKisah</h1>
    <p class="tagline">Buat akun untuk memulai perjalananmu.</p>

    <AlertMessage Message="@_error" IsError="true" Show="@_hasError" />

    <input @bind="_username" @bind:event="oninput"
           type="text" class="login-form-control"
           placeholder="Username" disabled="@_loading"
           @onkeydown="HandleKeyDown" />

    <button class="login-btn" @onclick="HandleRegister"
            disabled="@_loading">
        @(_loading ? "Mendaftarkan..." : "Daftar")
    </button>

    <p class="login-hint">
        Sudah punya akun?
        <a href="/" @onclick="GoToLogin" @onclick:preventDefault
           style="color: var(--color-primary); text-decoration: underline;">
            Masuk di sini
        </a>
    </p>

    <footer class="login-footer">
        myKisah v1.0
    </footer>
</div>

@code {
    private string _username = "";
    private string _error = "";
    private bool _hasError;
    private bool _loading;

    private void GoToLogin()
    {
        Navigation.NavigateTo("/");
    }

    private async Task HandleRegister()
    {
        var trimmed = _username.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            _hasError = true;
            _error = "Username tidak boleh kosong.";
            return;
        }

        _loading = true;
        _hasError = false;
        _error = "";

        try
        {
            var user = UserService.RegisterUser(trimmed);
            Session.Login(user);
            await JS.InvokeVoidAsync("sessionStorage.setItem", "myKisah.userId", user.Id);
            await JS.InvokeVoidAsync("location.replace", "/journals");
        }
        catch (Exception ex)
        {
            _loading = false;
            _hasError = true;
            _error = ex.Message;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleRegister();
    }
}
