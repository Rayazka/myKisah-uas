{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",

    "StoragePaths": {
        "UsersFile": "Data/users.json",
        "JournalsFile": "Data/journals.json",
        "CharactersFile": "Data/characters.json",
