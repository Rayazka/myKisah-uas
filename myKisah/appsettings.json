{
    // Bagian Logging digunakan untuk mengatur level informasi log aplikasi.
    "Logging": {
        "LogLevel": {
            // Default = log umum aplikasi akan ditampilkan pada level Information.
            "Default": "Information",

            // Microsoft.AspNetCore = log dari framework ASP.NET hanya ditampilkan
            // jika levelnya Warning atau lebih penting.
            "Microsoft.AspNetCore": "Warning"
        }
    },

    // AllowedHosts digunakan untuk menentukan host/domain yang boleh mengakses aplikasi.
    // Tanda "*" berarti semua host diperbolehkan.
    "AllowedHosts": "*",

    // StoragePaths adalah bagian utama dari tugas saya.
    // Bagian ini menerapkan teknik Runtime Configuration.
    // Path file JSON disimpan di konfigurasi, bukan ditulis langsung di source code.
    "StoragePaths": {
        // UsersFile adalah lokasi file JSON untuk menyimpan data user.
        "UsersFile": "Data/users.json",

        // JournalsFile adalah lokasi file JSON untuk menyimpan data jurnal.
        "JournalsFile": "Data/journals.json",

        // CharactersFile adalah lokasi file JSON untuk menyimpan data karakter companion.
        "CharactersFile": "Data/characters.json",

        // ResponsesFile adalah lokasi file JSON untuk menyimpan data respons karakter.
        "ResponsesFile": "Data/characterResponses.json"
    },

    // JournalConfig adalah konfigurasi tambahan untuk modul jurnal.
    // Bagian ini berisi aturan yang dapat dibaca saat aplikasi berjalan.
    "JournalConfig": {
        // MaxContentLength menentukan batas maksimal panjang isi jurnal.
        "MaxContentLength": 5000,

        // ValidMoods berisi daftar mood yang dianggap valid di aplikasi.
        "ValidMoods": [ "Happy", "Sad", "Angry", "Anxious", "Calm" ]
    }
}